RewriteEngine On

# Redirect /index or /index.php to the root domain
RewriteCond %{THE_REQUEST} \s/index(\.php)?\s [NC]
RewriteRule ^index(\.php)?$ / [L,R=301]

# Redirect /about-us to the home page about section
RewriteRule ^about-us/?$ /#about [L,R=301,NE]
# Unless directory, remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# News Slug Rewrite
RewriteRule ^news/([a-zA-Z0-9\-]+)\.html$ article.php?slug=$1 [L,QSA]

# Resolve .php file for extensionless urls
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Force lookups for sitemap.xml to be parsed securely via the dynamic PHP script pipeline
RewriteRule ^sitemap\.xml$ sitemap.php [L]
